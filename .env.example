# ──────────────────────────────────────────────
# Telegram
# ──────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# Restrict access by user ID (comma-separated). Empty = allow all.
# Numeric IDs only! Find your ID: message @userinfobot on Telegram
# Example: ALLOWED_USERS=123456789,987654321
# NOTE: @username is not supported, numeric IDs required
ALLOWED_USERS=

# ──────────────────────────────────────────────
# LLM (OpenRouter — OpenAI-compatible)
# Get API key at https://openrouter.ai/keys
# Free models: https://openrouter.ai/models?q=free
# Other backends: set LLM_BASE_URL to any OpenAI-compatible endpoint
# ──────────────────────────────────────────────
LLM_API_KEY=sk-or-your-key-here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3-235b-a22b:free

# ──────────────────────────────────────────────
# Whisper (STT)
# ──────────────────────────────────────────────
# Backend: "local" (faster-whisper, requires GPU) or "groq" (cloud, free tier)
WHISPER_BACKEND=local

# Local backend settings (ignored when WHISPER_BACKEND=groq)
# Models: tiny / base / small / medium / large-v3
# medium — good balance of speed and quality for Russian
# large-v3 — best quality, but ~3GB VRAM
WHISPER_MODEL=medium
WHISPER_DEVICE=cuda

# Groq backend settings (ignored when WHISPER_BACKEND=local)
# Get a free API key at https://console.groq.com
GROQ_API_KEY=

# ──────────────────────────────────────────────
# System prompt for LLM (path to .md file)
# Default: prompts/system.md — edit the file or point to a custom one
# ──────────────────────────────────────────────
SYSTEM_PROMPT=prompts/system.md

# ──────────────────────────────────────────────
# Google Docs (optional — leave empty to disable)
# ──────────────────────────────────────────────
# 1. Create a service account in GCP, download the JSON key
# 2. Enable the Google Docs API in your project
# 3. Open the target document and share it with the service account email (Editor)
# 4. Copy the document ID from the URL: .../document/d/<ID>/edit
GDOCS_CREDENTIALS_FILE=
GDOCS_DOCUMENT_ID=

# ──────────────────────────────────────────────
# Obsidian vault (optional — leave empty to disable)
# ──────────────────────────────────────────────
# Set to the local path of your vault (e.g. inside Yandex.Disk folder).
# Notes created in "note" mode will be written there automatically.
# Example (Linux): OBSIDIAN_VAULT_PATH=/home/user/YandexDisk/ObsidianVault
# Example (WSL):   OBSIDIAN_VAULT_PATH=/mnt/c/Users/user/YandexDisk/ObsidianVault
OBSIDIAN_VAULT_PATH=
# Subfolder within the vault where notes are saved (default: Inbox)
OBSIDIAN_INBOX_FOLDER=Inbox

# ──────────────────────────────────────────────
# Yandex.Disk (OAuth authentication — REQUIRED for Yandex.Disk access)
# ──────────────────────────────────────────────
# Users authenticate via OAuth button in /settings (no manual credentials).
# Direct login/password is DEPRECATED and removed from settings UI.
#
# Setup OAuth app:
#   1. Go to https://oauth.yandex.ru/client/new
#   2. Create new OAuth application
#   3. Set required scopes:
#      - login:info (Доступ к логину, имени и фамилии)
#      - cloud_api:disk.app_folder (Доступ к папке приложения на Диске)
#   4. Platform: Веб-сервисы (Web services)
#   5. Redirect URI: https://t.me/<your_bot_username>
#   6. Copy Client ID and Client Secret below
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=

# Yandex.Disk path (used for OAuth authentication)
# Folder path on Yandex.Disk to use as vault root
# Example: Apps/telegram-bot → saves to disk:/Apps/telegram-bot/Inbox/
YANDEX_DISK_PATH=Apps/telegram-bot

# ──────────────────────────────────────────────
# YouTube transcription
# ──────────────────────────────────────────────
# Max video duration in seconds (default: 2 hours)
YT_MAX_DURATION=7200

# Cookie file for yt-dlp (Netscape format). Required if YouTube blocks downloads.
# Export from browser in incognito using "Get cookies.txt LOCALLY" extension.
# Use a throwaway Google account. chmod 600 the file.
YT_COOKIES_FILE=

# ──────────────────────────────────────────────
# HuggingFace (for diarization — used by bot and tools/transcribe_diarize.py)
# ──────────────────────────────────────────────
# 1. Create an account at huggingface.co (free)
# 2. Accept license: huggingface.co/pyannote/speaker-diarization-3.1
# 3. Accept license: huggingface.co/pyannote/segmentation-3.0
# 4. Create a token: huggingface.co/settings/tokens
HF_TOKEN=

# ──────────────────────────────────────────────
# Internationalization
# ──────────────────────────────────────────────
# Default bot language: 'ru' (Russian) or 'en' (English)
DEFAULT_LANGUAGE=ru

# ──────────────────────────────────────────────
# Database Encryption (REQUIRED for SQLite persistence)
# ──────────────────────────────────────────────
# Master encryption key for sensitive data (OAuth tokens, API keys, passwords).
# 
# IMPORTANT: 
#   - If not set, a key is auto-generated and stored in data/master.key
#   - For production: ALWAYS set this in env var or secrets manager
#   - BACK UP THIS KEY! Loss = permanent data loss for encrypted fields
#   - Store separately from database backup
#
# Generate new key:
#   python -c "from db.encryption import generate_key; print(generate_key())"
#
# Then set: ENCRYPTION_KEY=<generated_key>
ENCRYPTION_KEY=

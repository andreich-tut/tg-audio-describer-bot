{$DOMAIN:localhost} {
    # Proxy API calls to FastAPI backend (running inside bot process)
    handle /api/* {
        reverse_proxy bot:8080
    }

    # Swagger UI and OpenAPI documentation
    handle /docs {
        reverse_proxy bot:8080
    }

    handle /docs/* {
        reverse_proxy bot:8080
    }

    handle /redoc {
        reverse_proxy bot:8080
    }

    handle /openapi.json {
        reverse_proxy bot:8080
    }

    # Default: return 404 for all other paths
    handle {
        respond 404
    }
}

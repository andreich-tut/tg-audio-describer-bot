[MAIN]
# Use multiple processes to speed up Pylint
jobs=1

# Ignore migration files (Alembic conventions differ from PEP8)
ignore=alembic/versions

[MESSAGES CONTROL]
disable=
    # Style/formatting — not real bugs
    missing-function-docstring,
    missing-module-docstring,
    missing-class-docstring,
    line-too-long,
    # Refactor hints — not real bugs
    too-many-locals,
    too-many-branches,
    too-many-statements,
    too-many-return-statements,
    too-many-arguments,
    too-many-positional-arguments,
    too-many-public-methods,
    too-few-public-methods,
    duplicate-code,
    # Intentional patterns in async bot handlers
    broad-exception-caught,
    # Conditional/deferred imports (e.g. optional GPU libs, lazy imports)
    import-outside-toplevel,
    wrong-import-position,
    wrong-import-order,
    # subprocess.run without check= — intentional in CLI tools
    subprocess-run-check,
    # False positives from dynamic APIs (Google API client, openai **kwargs)
    no-member,
    missing-kwoa,
    # SQLAlchemy/Alembic conventions
    invalid-name,  # Alembic migration files, SQLAlchemy func
    not-callable,  # SQLAlchemy func.now() is dynamic
    # Singleton pattern (database connection)
    global-statement,
    # Sync wrapper pattern (reimport asyncio for each wrapper)
    redefined-outer-name,
    reimported,
    unnecessary-pass,  # Dataclasses with pass
    # Refactor suggestions
    no-else-return,
    # tools/ scripts importing from sibling scripts by path
    no-name-in-module,
    # GPU/optional packages not installed in CI (faster-whisper, whisperx, torch)
    import-error,
    # Unused in some locales/callbacks by design
    unused-argument,
    unused-variable,
    # Re-export modules (intentional wildcard imports in state.py, config.py, bot.py)
    wildcard-import,
    unused-wildcard-import,

[FORMAT]
max-line-length=120

[DESIGN]
max-locals=30
max-branches=20
max-statements=70

[SIMILARITIES]
# Ignore boilerplate in CLI tools
min-similarity-lines=10
